[
  {
    "name": "AcmeUI",
    "patterns": [
      "AcmeUI\\.init",
      "__ACME_UI__",
      "acme-ui-version"
    ],
    "version_regex": "AcmeUI\\.version\\s*=\\s*[\"']([0-9.]+)[\"']"
  },
  {
    "name": "AcmeRouter",
    "patterns": [
      "AcmeRouter\\.navigate",
      "__ACME_ROUTER__",
      "acmeRouterConfig"
    ],
    "version_regex": null
  },
  {
    "name": "AcmeStateManager",
    "patterns": [
      "AcmeStore\\.createStore",
      "useAcmeState",
      "__ACME_STORE__"
    ],
    "version_regex": "AcmeStore\\.version\\s*=\\s*[\"']([0-9.]+)[\"']"
  }
]
